<div class="box as-bar">
  <% if request.subdomain == 'admin' %>
    <%= link_to('/', class: 'px-4') do %>
      <%= svg_tag 'angle-left' %>
    <% end %>
  <% else %>
    <%= link_to({ controller: '/my/home' }, class: 'px-4') do %>
      <%= svg_tag 'angle-left' %>
    <% end %>
  <% end %>
  <span class="weui-title"><%= t('.title') %></span>
  <i class="px-5"></i>
</div>
