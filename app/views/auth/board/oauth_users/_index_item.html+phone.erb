<div class="is-several">
  <%= image_tag model.avatar_url, class: 'image is-24x24' if model.avatar_url %>
  <span><%= model.name %></span>
</div>
<% if model.identity.present? %>
  <p><%= model.identity %></p>
<% end %>
<div class="tags has-addons">
  <span class="tag"><%= model.type_i18n %></span>
  <% if model.app_name.present? %>
    <span class="tag is-light is-info"><%= model.app_name %></span>
  <% end %>
</div>
