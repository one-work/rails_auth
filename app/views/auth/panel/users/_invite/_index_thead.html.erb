<th><%= Auth::User.human_attribute_name(:name) %></th>
<th><%= Auth::User.human_attribute_name(:invite_code) %></th>
<th><%= Auth::User.human_attribute_name(:locale) %></th>
<th><%= Auth::User.human_attribute_name(:timezone) %></th>
<th><%= Auth::User.human_attribute_name(:last_login_ip) %></th>
<th>
  <%= link_to filter_params('last_login_at-desc': 1) do %>
    <span class="text-grey"><%= Auth::User.human_attribute_name(:last_login_at) %></span>
    <%= svg_tag 'arrow-down', class: "icon is-small #{params['last_login_at-desc'] ? 'text-success' : 'text-grey'}" %>
  <% end %>
</th>
<th><%= Auth::User.human_attribute_name(:disabled) %></th>
<th><%= Auth::User.human_attribute_name(:created_at) %></th>
